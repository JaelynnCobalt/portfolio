<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Commissions & Services</title>
    <link href="https://fonts.googleapis.com/css2?family=Cherry+Bomb+One&family=Fredoka:wght@400;600&display=swap" rel="stylesheet">
    <style>
        @page {
            size: A4;
            margin: 0;
            background-color: #8B63A9; /* Deep Groovy Purple */
        }
        
        body {
            margin: 0;
            padding: 40px;
            font-family: 'Fredoka', sans-serif;
            background-color: #8B63A9;
            color: #2D2D2D;
        }

        .header-banner {
            background-color: #FF6B35; /* Retro Orange */
            padding: 40px;
            border-bottom: 8px solid #2D2D2D;
            text-align: center;
            margin: -40px -40px 40px -40px;
            position: relative;
        }

        h1 {
            font-family: 'Cherry Bomb One', cursive;
            font-size: 42pt;
            color: #F4F1DE; /* Cream */
            margin: 0;
            text-shadow: 4px 4px #2D2D2D;
            letter-spacing: 2px;
        }

        .subtitle {
            color: #F4F1DE;
            font-size: 14pt;
            font-weight: 600;
            margin-top: 10px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
        }

        .service-section {
            background: #F4F1DE;
            border: 5px solid #2D2D2D;
            border-radius: 40px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 10px 10px 0px #FFB30D; /* Yellow Pop shadow */
            position: relative;
        }

        .service-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 3px dashed #FF6B35;
            padding-bottom: 10px;
        }

        .service-icon {
            width: 50px;
            height: 50px;
            background: #FFB30D;
            border: 3px solid #2D2D2D;
            border-radius: 50%;
            margin-right: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20pt;
        }

        h2 {
            font-family: 'Cherry Bomb One', cursive;
            font-size: 22pt;
            margin: 0;
            color: #8B63A9;
        }

        .pricing-grid {
            display: table;
            width: 100%;
            border-spacing: 0 10px;
        }

        .price-row {
            display: table-row;
        }

        .item-name {
            display: table-cell;
            font-weight: 600;
            font-size: 12pt;
            padding: 5px 0;
        }

        .item-price {
            display: table-cell;
            text-align: right;
            font-weight: 600;
            color: #FF6B35;
            font-size: 14pt;
        }

        .description {
            font-size: 10pt;
            color: #555;
            margin-top: -5px;
            padding-bottom: 10px;
        }

        .terms-box {
            background: #FFB30D;
            border: 4px solid #2D2D2D;
            border-radius: 20px;
            padding: 20px;
            margin-top: 20px;
        }

        .terms-box h3 {
            font-family: 'Cherry Bomb One', cursive;
            margin-top: 0;
            font-size: 16pt;
        }

        .footer-note {
            text-align: center;
            color: #F4F1DE;
            font-weight: 600;
            margin-top: 40px;
        }

        .daisy {
            position: absolute;
            bottom: -20px;
            right: -20px;
            width: 60px;
            height: 60px;
            background: white;
            border: 3px solid #2D2D2D;
            border-radius: 50%;
        }
        .daisy-inner {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 25px;
            height: 25px;
            background: #FFB30D;
            border: 2px solid #2D2D2D;
            border-radius: 50%;
        }
    </style>
</head>
<body>
    <div class="header-banner">
        <h1>Groovy Services</h1>
        <div class="subtitle">Art • Writing • Languages • Proofreading</div>
    </div>

    <div class="container">
        <!-- ART SECTION -->
        <div class="service-section">
            <div class="service-header">
                <div class="service-icon">🎨</div>
                <h2>Art Commissions</h2>
            </div>
            <div class="pricing-grid">
                <div class="price-row">
                    <div class="item-name">Character Headshot</div>
                    <div class="item-price">$25.00</div>
                </div>
                <div class="description">Fully colored and shaded circular portrait.</div>
                
                <div class="price-row">
                    <div class="item-name">Full Body Illustration</div>
                    <div class="item-price">$65.00</div>
                </div>
                <div class="description">Detailed character with simple background.</div>
            </div>
        </div>

        <!-- WRITING SECTION -->
        <div class="service-section">
            <div class="service-header">
                <div class="service-icon">✍️</div>
                <h2>Creative Writing</h2>
            </div>
            <div class="pricing-grid">
                <div class="price-row">
                    <div class="item-name">Short Stories</div>
                    <div class="item-price">$0.05 / word</div>
                </div>
                <div class="description">Fiction or non-fiction, tailored to your prompts.</div>
                
                <div class="price-row">
                    <div class="item-name">Poetry / Lyrics</div>
                    <div class="item-price">$30.00 / piece</div>
                </div>
                <div class="description">Up to 30 lines of custom verse.</div>
            </div>
        </div>

        <!-- LANGUAGE SECTION -->
        <div class="service-section">
            <div class="service-header">
                <div class="service-icon">🌍</div>
                <h2>Language & Editing</h2>
            </div>
            <div class="pricing-grid">
                <div class="price-row">
                    <div class="item-name">Proofreading & Polishing</div>
                    <div class="item-price">$10.00 / page</div>
                </div>
                <div class="description">Grammar, flow, and clarity check for essays or blogs.</div>
                
                <div class="price-row">
                    <div class="item-name">Translation (ES/EN)</div>
                    <div class="item-price">$0.08 / word</div>
                </div>
                <div class="description">Accurate and natural sounding translations.</div>
            </div>
            <div class="daisy"><div class="daisy-inner"></div></div>
        </div>

        <!-- TERMS -->
        <div class="terms-box">
            <h3>The Fine Print (Peace & Love)</h3>
            <ul style="margin: 0; padding-left: 20px; font-size: 10pt;">
                <li>50% upfront deposit required for all new clients.</li>
                <li>Turnaround time is usually 7-14 days.</li>
                <li>Two rounds of revisions included for free!</li>
            </ul>
        </div>

        <div class="footer-note">
            Ready to start? Send a DM or Email at hello@groovysite.com
        </div>
    </div>
</body>
</html>
